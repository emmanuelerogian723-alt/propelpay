# PropelPay Environment Variables
# Copy this file to .env and fill in your values

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
SECRET_KEY=your-random-secret-key-here
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, good for getting started):
DATABASE_URL=sqlite+aiosqlite:///./propelpay.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/propelpay

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=another-random-secret-key-here

# ── AI (get free key at console.groq.com) ──────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Fallback (optional):
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxx

# ── Payments ──────────────────────────────────────────────────────────────────
# Get from paystack.com/settings/developer
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# ── Email (Gmail SMTP — use App Password, not your main password) ──────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourname@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_NAME=PropelPay
